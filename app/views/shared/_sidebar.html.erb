<aside class="hidden lg:flex fixed inset-y-0 left-0 w-64 flex-col bg-slate-900 border-r border-slate-800">
  <div class="h-16 flex items-center gap-3 px-6 border-b border-slate-800">
    <span class="w-9 h-9 rounded-lg bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white">
      <%= heroicon :sparkles, klass: "w-5 h-5" %>
    </span>
    <div class="leading-tight">
      <p class="font-semibold text-slate-100">BankLinker</p>
      <p class="text-xs text-slate-500">Budget control</p>
    </div>
  </div>

  <nav class="flex-1 px-3 py-6 space-y-1">
    <% nav_items = [
      { label: "Dashboard", path: root_path, icon: :home, active: current_page?(root_path) },
      { label: "Categorizar", path: transactions_path, icon: :rectangle_stack, active: current_page?(transactions_path) },
      { label: "Pockets", path: pockets_path, icon: :tag, active: request.path.start_with?("/pockets") },
      { label: "Exportar CSV", path: export_transactions_path, icon: :arrow_down_tray, active: false }
    ] %>

    <% nav_items.each do |item| %>
      <%= link_to item[:path],
            class: "group flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition #{item[:active] ? 'bg-slate-800 text-slate-100' : 'text-slate-400 hover:text-slate-100 hover:bg-slate-800/60'}" do %>
        <span class="<%= item[:active] ? 'text-violet-400' : 'text-slate-500 group-hover:text-slate-300' %>">
          <%= heroicon item[:icon], klass: "w-5 h-5" %>
        </span>
        <%= item[:label] %>
      <% end %>
    <% end %>
  </nav>

  <div class="p-4 border-t border-slate-800">
    <div class="rounded-xl bg-gradient-to-br from-violet-600/20 to-indigo-600/10 border border-violet-500/20 p-4">
      <p class="text-xs uppercase tracking-wide text-violet-300 font-semibold">Tip</p>
      <p class="text-sm text-slate-300 mt-1 leading-snug">Los extractos de RappiPay vienen cifrados. Guarda tu contraseña a mano.</p>
    </div>
  </div>
</aside>
