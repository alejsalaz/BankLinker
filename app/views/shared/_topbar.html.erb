<header class="h-16 flex items-center justify-between px-6 lg:px-10 bg-slate-950/80 backdrop-blur border-b border-slate-800 sticky top-0 z-10">
  <div class="flex items-center gap-2 text-sm text-slate-400">
    <span class="lg:hidden font-semibold text-slate-100 flex items-center gap-2">
      <%= heroicon :sparkles, klass: "w-5 h-5 text-violet-400" %>
      BankLinker
    </span>
    <span class="hidden lg:inline"><%= content_for(:breadcrumb) || "Panel" %></span>
  </div>

  <div class="flex items-center gap-3">
    <%= link_to export_transactions_path, class: "hidden sm:inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm bg-slate-900 border border-slate-800 text-slate-300 hover:text-slate-100 hover:border-slate-700 transition" do %>
      <%= heroicon :arrow_down_tray, klass: "w-4 h-4" %>
      Exportar
    <% end %>
    <%= link_to root_path, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm bg-violet-600 hover:bg-violet-500 text-white transition" do %>
      <%= heroicon :arrow_up_tray, klass: "w-4 h-4" %>
      Subir extracto
    <% end %>
  </div>
</header>
