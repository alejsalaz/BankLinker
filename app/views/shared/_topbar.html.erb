<header class="h-16 flex items-center justify-between gap-3 px-4 sm:px-6 lg:px-10 bg-slate-950/80 backdrop-blur border-b border-slate-800 sticky top-0 z-20">
  <div class="flex items-center gap-2 text-sm text-slate-400 min-w-0">
    <button type="button"
            data-sidebar-toggle
            class="lg:hidden text-slate-300 hover:text-white p-2 -ml-2 rounded-lg hover:bg-slate-800 cursor-pointer"
            aria-label="<%= t('nav.open_menu') %>">
      <%= heroicon :bars_3, klass: "w-6 h-6" %>
    </button>
    <span class="lg:hidden font-semibold text-slate-100 flex items-center gap-2 truncate">
      <%= heroicon :sparkles, klass: "w-5 h-5 text-violet-400 shrink-0" %>
      <span class="truncate"><%= t("banklinker.app_name") %></span>
    </span>
  </div>

  <div class="flex items-center gap-2">
    <%= link_to export_transactions_path, class: "hidden sm:inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm bg-slate-900 border border-slate-800 text-slate-300 hover:text-slate-100 hover:border-slate-700 transition" do %>
      <%= heroicon :arrow_down_tray, klass: "w-4 h-4" %>
      <%= t("nav.export_csv") %>
    <% end %>
    <%= link_to root_path, class: "inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm bg-violet-600 hover:bg-violet-500 text-white transition" do %>
      <%= heroicon :arrow_up_tray, klass: "w-4 h-4" %>
      <span class="hidden sm:inline"><%= t("nav.upload_statement") %></span>
    <% end %>
  </div>
</header>
