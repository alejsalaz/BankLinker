<%= form_with model: ivy_category, class: "space-y-5" do |f| %>
  <% if ivy_category.errors.any? %>
    <div class="rounded-xl border border-rose-500/40 bg-rose-500/10 text-rose-200 p-4 text-sm">
      <p class="font-medium mb-1">Revisa los campos:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% ivy_category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nombre", class: "block text-sm font-medium text-slate-300 mb-1.5" %>
    <%= f.text_field :name,
          class: "w-full rounded-lg bg-slate-950 border border-slate-800 focus:border-emerald-500/60 focus:ring-2 focus:ring-emerald-500/30 px-3 py-2 text-slate-100 placeholder-slate-500 outline-none",
          placeholder: "Ej. Alimentación" %>
  </div>

  <div class="flex gap-3 pt-2">
    <%= f.submit ivy_category.persisted? ? "Guardar cambios" : "Crear categoría",
          class: "px-5 py-2.5 rounded-lg bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-semibold cursor-pointer transition" %>
    <% if ivy_category.persisted? %>
      <%= link_to "Cancelar", ivy_categories_path,
            class: "px-5 py-2.5 rounded-lg bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium transition" %>
    <% end %>
  </div>
<% end %>
