<% content_for :title, "Inicio - BankLinker" %>
<% content_for :breadcrumb, "Inicio" %>

<section class="space-y-8 max-w-6xl">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-100"><%= t("dashboard.title") %></h1>
      <p class="text-slate-400 mt-1"><%= t("dashboard.subtitle") %></p>
    </div>
  </div>

  <% if @processed_count.positive? %>
    <div class="rounded-xl border border-sky-500/30 bg-sky-500/10 text-sky-100 px-4 py-3 text-sm flex items-start gap-3">
      <span class="shrink-0 text-sky-300 mt-0.5"><%= heroicon :arrow_down_tray, klass: "w-5 h-5" %></span>
      <div>
        <p class="font-medium text-sky-100"><%= t("dashboard.csv_format.title") %></p>
        <p class="text-sky-200/80"><%= t("dashboard.csv_format.body_html").html_safe %></p>
      </div>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
    <%= render "metric_card",
          icon: :clock,
          label: t("dashboard.metrics.pending"),
          value: @pending_count,
          accent: "amber",
          action_label: (t("dashboard.actions.categorize_now") if @pending_count.positive?),
          action_path: transactions_path %>

    <%= render "metric_card",
          icon: :check_circle,
          label: t("dashboard.metrics.processed"),
          value: @processed_count,
          accent: "emerald",
          action_label: (t("dashboard.actions.download_csv") if @processed_count.positive?),
          action_path: export_transactions_path %>

    <%= render "metric_card",
          icon: :tag,
          label: t("dashboard.metrics.envelopes"),
          value: @envelopes_count,
          accent: "violet",
          action_label: t("nav.envelopes"),
          action_path: envelopes_path %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
    <div class="lg:col-span-2 bg-slate-900 rounded-2xl border border-slate-800 p-6">
      <div class="flex items-start justify-between mb-6 gap-4">
        <div>
          <h2 class="text-lg font-semibold text-slate-100">Subir extracto</h2>
          <p class="text-sm text-slate-400 mt-1">Aceptamos PDF y imágenes. Los PDFs protegidos necesitan contraseña.</p>
        </div>
        <div class="flex items-center gap-2">
          <% if @pending_count.positive? || @processed_count.positive? %>
            <%= button_to reset_transactions_path,
                  method: :delete,
                  form: { data: { turbo_confirm: t("transactions.categorize.queue.confirm_reset") } },
                  class: "inline-flex items-center gap-1 text-xs text-rose-300 hover:text-rose-200 bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/30 px-2.5 py-1.5 rounded-lg cursor-pointer transition" do %>
              <%= heroicon :trash, klass: "w-3.5 h-3.5" %>
              <%= t("transactions.categorize.queue.reset") %>
            <% end %>
          <% end %>
          <span class="w-10 h-10 rounded-lg bg-violet-500/10 border border-violet-500/30 flex items-center justify-center text-violet-300">
            <%= heroicon :document_arrow_up, klass: "w-5 h-5" %>
          </span>
        </div>
      </div>

      <%= form_with url: upload_dashboard_path, method: :post, multipart: true, local: true, class: "space-y-5" do |f| %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= f.label :extractor_type, "Tipo de extracto", class: "block text-xs font-medium uppercase tracking-wide text-slate-400 mb-2" %>
            <%= f.select :extractor_type, @extractor_types.map { |t| [t.to_s.titleize, t] }, {},
                  class: "block w-full rounded-lg bg-slate-950 border border-slate-800 text-slate-100 text-sm px-3 py-2.5 focus:border-violet-500 focus:ring-1 focus:ring-violet-500" %>
          </div>

          <div>
            <%= f.label :password, "Contraseña del PDF", class: "block text-xs font-medium uppercase tracking-wide text-slate-400 mb-2" %>
            <div class="relative">
              <span class="absolute inset-y-0 left-3 flex items-center text-slate-500">
                <%= heroicon :lock_closed, klass: "w-4 h-4" %>
              </span>
              <%= f.password_field :password, autocomplete: "off", placeholder: "Opcional",
                    class: "block w-full rounded-lg bg-slate-950 border border-slate-800 text-slate-100 text-sm pl-9 pr-3 py-2.5 focus:border-violet-500 focus:ring-1 focus:ring-violet-500" %>
            </div>
          </div>
        </div>

        <div>
          <%= f.label :file, "Archivo", class: "block text-xs font-medium uppercase tracking-wide text-slate-400 mb-2" %>
          <label class="flex flex-col items-center justify-center gap-2 border border-dashed border-slate-700 hover:border-violet-500/50 rounded-xl px-6 py-8 bg-slate-950/60 cursor-pointer transition">
            <span class="w-10 h-10 rounded-full bg-violet-500/10 text-violet-300 flex items-center justify-center">
              <%= heroicon :arrow_up_tray, klass: "w-5 h-5" %>
            </span>
            <span class="text-sm text-slate-300">Arrastra o selecciona un PDF / imagen</span>
            <span class="text-xs text-slate-500">Se procesa localmente, no se guarda el archivo.</span>
            <%= f.file_field :file, accept: ".pdf,image/*", required: true,
                  class: "mt-1 block w-full text-xs text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-violet-600 file:text-white file:text-sm hover:file:bg-violet-500 cursor-pointer" %>
          </label>
        </div>

        <div class="flex items-center justify-between pt-2">
          <p class="text-xs text-slate-500">Tip: para OCR necesitas <code class="bg-slate-800 px-1.5 py-0.5 rounded text-slate-300">tesseract-ocr</code> instalado.</p>
          <%= f.submit "Procesar extracto",
                class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition" %>
        </div>
      <% end %>
    </div>

    <div class="bg-slate-900 rounded-2xl border border-slate-800 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-slate-100">Sobres</h2>
        <%= link_to envelopes_path, class: "text-xs text-violet-400 hover:text-violet-300 inline-flex items-center gap-1" do %>
          Ver todos <%= heroicon :chevron_right, klass: "w-3.5 h-3.5" %>
        <% end %>
      </div>

      <% if @envelopes.any? %>
        <ul class="space-y-2">
          <% @envelopes.each do |envelope| %>
            <li class="flex items-center justify-between px-3 py-2.5 rounded-lg bg-slate-950/60 border border-slate-800">
              <div class="flex items-center gap-3">
                <span class="w-2.5 h-2.5 rounded-full <%= envelope.dot_classes %>"></span>
                <span class="text-sm text-slate-200"><%= envelope.name %></span>
              </div>
              <span class="text-xs text-slate-500"><%= envelope.transactions.count %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-slate-400">Aún no hay sobres. <%= link_to "Crea el primero", envelopes_path, class: "text-violet-400 hover:text-violet-300" %>.</p>
      <% end %>
    </div>
  </div>
</section>
