<% if transaction.nil? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center">
    <h2 class="text-2xl font-semibold text-slate-800">No hay transacciones pendientes</h2>
    <p class="text-slate-500 mt-2">Sube un nuevo extracto o exporta las procesadas a Ivy Wallet.</p>
    <div class="flex justify-center gap-3 mt-6">
      <%= link_to "Subir extracto", root_path, class: "bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-5 py-2.5 rounded-lg" %>
      <%= link_to "Exportar CSV", export_transactions_path, class: "bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-5 py-2.5 rounded-lg" %>
    </div>
  </div>
<% elsif pockets.empty? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-10 text-center">
    <h2 class="text-2xl font-semibold text-slate-800">No tienes pockets configurados</h2>
    <p class="text-slate-500 mt-2">Crea al menos un pocket antes de categorizar.</p>
    <%= link_to "Configurar pockets", pockets_path, class: "inline-block mt-6 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-5 py-2.5 rounded-lg" %>
  </div>
<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 p-8 shadow-sm transition duration-200 ease-out">
    <div class="flex items-start justify-between">
      <div>
        <p class="text-sm uppercase tracking-wide text-slate-500">Fecha</p>
        <p class="text-lg font-medium text-slate-800"><%= l(transaction.date, format: :long) rescue transaction.date.to_s %></p>
      </div>
      <div class="text-right">
        <p class="text-sm uppercase tracking-wide text-slate-500">Monto</p>
        <p class="text-3xl font-bold <%= transaction.amount.negative? ? 'text-rose-600' : 'text-emerald-600' %>">
          <%= number_to_currency(transaction.amount, unit: "$", separator: ",", delimiter: ".", precision: 2) %>
        </p>
      </div>
    </div>

    <div class="mt-6">
      <p class="text-sm uppercase tracking-wide text-slate-500">Descripción</p>
      <p class="text-xl font-semibold text-slate-900 mt-1"><%= transaction.description %></p>
    </div>

    <div class="mt-8 grid grid-cols-2 md:grid-cols-3 gap-3">
      <% pockets.each do |pocket| %>
        <%= button_to categorize_transaction_path(transaction, pocket_id: pocket.id),
              method: :patch,
              form: { data: { turbo_stream: true } },
              class: "#{pocket.button_classes} text-white font-semibold py-4 rounded-xl text-lg shadow-sm transition transform hover:scale-[1.02] active:scale-[0.98] cursor-pointer" do %>
          <%= pocket.name %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
