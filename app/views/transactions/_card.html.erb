<% if transaction.nil? %>
  <div class="bg-slate-900 rounded-2xl border border-slate-800 p-10 text-center">
    <span class="mx-auto w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 flex items-center justify-center">
      <%= heroicon :check_circle, klass: "w-6 h-6" %>
    </span>
    <h2 class="text-2xl font-semibold text-slate-100 mt-4">Todo al día</h2>
    <p class="text-slate-400 mt-2">No hay movimientos pendientes. Sube otro extracto o exporta lo categorizado.</p>
    <div class="flex justify-center gap-3 mt-6">
      <%= link_to root_path, class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-5 py-2.5 rounded-lg" do %>
        <%= heroicon :arrow_up_tray, klass: "w-4 h-4" %>
        Subir extracto
      <% end %>
      <%= link_to export_transactions_path, class: "inline-flex items-center gap-2 bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 hover:bg-emerald-500/20 font-semibold px-5 py-2.5 rounded-lg" do %>
        <%= heroicon :arrow_down_tray, klass: "w-4 h-4" %>
        Exportar CSV
      <% end %>
    </div>
  </div>
<% elsif envelopes.empty? %>
  <div class="bg-slate-900 rounded-2xl border border-slate-800 p-10 text-center">
    <span class="mx-auto w-12 h-12 rounded-full bg-amber-500/10 border border-amber-500/30 text-amber-300 flex items-center justify-center">
      <%= heroicon :tag, klass: "w-6 h-6" %>
    </span>
    <h2 class="text-2xl font-semibold text-slate-100 mt-4">No tienes sobres configurados</h2>
    <p class="text-slate-400 mt-2">Crea al menos un sobre antes de categorizar.</p>
    <%= link_to envelopes_path, class: "inline-flex items-center gap-2 mt-6 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-5 py-2.5 rounded-lg" do %>
      <%= heroicon :plus, klass: "w-4 h-4" %>
      Configurar sobres
    <% end %>
  </div>
<% else %>
  <div class="relative bg-gradient-to-br from-slate-900 to-slate-900/40 rounded-2xl border border-slate-800 p-8 shadow-2xl shadow-black/40 transition duration-200 ease-out">
    <span class="absolute inset-x-8 -top-px h-px bg-gradient-to-r from-transparent via-violet-500/40 to-transparent"></span>

    <div class="flex items-start justify-between gap-6">
      <div class="space-y-1">
        <span class="inline-flex items-center gap-2 px-2.5 py-1 rounded-full text-xs font-medium bg-slate-800 text-slate-300 border border-slate-700">
          <%= heroicon :clock, klass: "w-3.5 h-3.5" %>
          <%= l(transaction.date, format: :long) rescue transaction.date.to_s %>
        </span>
        <p class="text-sm text-slate-400 pt-3">Descripción</p>
        <p class="text-2xl font-semibold text-slate-100 break-words"><%= transaction.description %></p>
      </div>
      <div class="text-right shrink-0">
        <p class="text-xs uppercase tracking-wide text-slate-500">Monto</p>
        <p class="text-3xl md:text-4xl font-bold mt-1 <%= transaction.amount.negative? ? 'text-rose-400' : 'text-emerald-400' %>">
          <%= number_to_currency(transaction.amount, unit: "$", separator: ",", delimiter: ".", precision: 2) %>
        </p>
      </div>
    </div>

    <div class="mt-8">
      <p class="text-xs uppercase tracking-wide text-slate-500 mb-3">Asignar a sobre</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        <% envelopes.each do |envelope| %>
          <%= button_to categorize_transaction_path(transaction, envelope_id: envelope.id),
                method: :patch,
                form: { data: { turbo_stream: true }, class: "block w-full" },
                class: "#{envelope.button_classes} w-full rounded-xl py-4 px-4 font-semibold text-base transition transform hover:scale-[1.02] active:scale-[0.98] cursor-pointer flex items-center gap-3 text-left" do %>
            <span class="w-2.5 h-2.5 rounded-full shrink-0 <%= envelope.dot_classes %>"></span>
            <span class="flex-1 truncate"><%= envelope.name %></span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
