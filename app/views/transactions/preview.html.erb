<% content_for :title, "#{t('transactions.preview.title')} - #{t('banklinker.app_name')}" %>
<% content_for :breadcrumb, t("transactions.preview.title") %>

<section class="space-y-6 max-w-6xl">
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-100"><%= t("transactions.preview.title") %></h1>
      <p class="text-slate-400 mt-1">
        <%= t("transactions.preview.subtitle_html",
              count: @staging_transactions.size,
              from: @date_from.strftime("%d/%m/%Y"),
              to: @date_to.strftime("%d/%m/%Y")).html_safe %>
      </p>
    </div>
    <%= button_to t("transactions.preview.discard_all"),
          discard_preview_transactions_path,
          method: :delete,
          form: { data: { turbo_confirm: t("transactions.preview.discard_all") + "?" } },
          class: "inline-flex items-center gap-1 text-xs text-rose-300 hover:text-rose-200 bg-rose-500/10 hover:bg-rose-500/20 border border-rose-500/30 px-3 py-2 rounded-lg cursor-pointer transition shrink-0" %>
  </div>

  <div class="bg-slate-900 border border-slate-800 rounded-2xl p-4 flex flex-col md:flex-row md:items-end gap-4">
    <div class="flex-1">
      <p class="text-xs uppercase tracking-wide text-slate-500 mb-2"><%= t("transactions.preview.range.title") %></p>
      <p class="text-sm text-slate-400"><%= t("transactions.preview.range.hint") %></p>
    </div>
    <div class="grid grid-cols-2 gap-3">
      <label class="flex flex-col gap-1 text-xs uppercase tracking-wide text-slate-500">
        <%= t("transactions.preview.range.from") %>
        <input type="date" id="range-from"
               min="<%= @date_from.iso8601 %>" max="<%= @date_to.iso8601 %>"
               value="<%= @date_from.iso8601 %>"
               class="rounded-lg bg-slate-950 border border-slate-800 focus:border-violet-500/60 focus:ring-2 focus:ring-violet-500/30 px-3 py-2 text-sm text-slate-100 outline-none" />
      </label>
      <label class="flex flex-col gap-1 text-xs uppercase tracking-wide text-slate-500">
        <%= t("transactions.preview.range.to") %>
        <input type="date" id="range-to"
               min="<%= @date_from.iso8601 %>" max="<%= @date_to.iso8601 %>"
               value="<%= @date_to.iso8601 %>"
               class="rounded-lg bg-slate-950 border border-slate-800 focus:border-violet-500/60 focus:ring-2 focus:ring-violet-500/30 px-3 py-2 text-sm text-slate-100 outline-none" />
      </label>
    </div>
    <button type="button" id="apply-range"
            class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white text-sm px-4 py-2 rounded-lg cursor-pointer transition">
      <%= heroicon :check_circle, klass: "w-4 h-4" %>
      <%= t("transactions.preview.range.apply") %>
    </button>
  </div>

  <%= form_with url: confirm_preview_transactions_path, method: :post, local: true, id: "preview-form" do %>
    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-800 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
        <div class="flex items-center gap-2 text-sm text-slate-400">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" id="toggle-all" checked
                   class="w-4 h-4 rounded border-slate-700 bg-slate-950 text-violet-500 focus:ring-violet-500/50" />
            <span><%= t("transactions.preview.toggle_all") %></span>
          </label>
          <span id="selected-counter" class="text-xs text-slate-500 ml-3"></span>
        </div>
        <button type="submit"
                class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-semibold px-4 py-2 rounded-lg cursor-pointer transition">
          <%= heroicon :check_circle, klass: "w-4 h-4" %>
          <%= t("transactions.preview.confirm_import") %>
        </button>
      </div>

      <table class="w-full text-sm">
        <thead class="bg-slate-950/40 text-slate-500 uppercase text-xs">
          <tr>
            <th class="px-4 py-3 text-left font-medium w-10"></th>
            <th class="px-4 py-3 text-left font-medium"><%= t("transactions.preview.headers.date") %></th>
            <th class="px-4 py-3 text-left font-medium"><%= t("transactions.preview.headers.description") %></th>
            <th class="px-4 py-3 text-left font-medium"><%= t("transactions.preview.headers.type") %></th>
            <th class="px-4 py-3 text-right font-medium"><%= t("transactions.preview.headers.amount") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-800">
          <% @staging_transactions.each do |tx| %>
            <tr class="hover:bg-slate-800/40 transition">
              <td class="px-4 py-3">
                <input type="checkbox" name="keep_ids[]" value="<%= tx.id %>" checked
                       data-date="<%= tx.date.iso8601 %>"
                       class="preview-keep w-4 h-4 rounded border-slate-700 bg-slate-950 text-violet-500 focus:ring-violet-500/50" />
              </td>
              <td class="px-4 py-3 text-slate-300 whitespace-nowrap"><%= tx.date.strftime("%d/%m/%Y") %></td>
              <td class="px-4 py-3 text-slate-200"><%= tx.description %></td>
              <td class="px-4 py-3">
                <% type_classes = { "expense" => "bg-rose-500/10 border-rose-500/30 text-rose-300",
                                    "income"  => "bg-emerald-500/10 border-emerald-500/30 text-emerald-300",
                                    "transfer" => "bg-sky-500/10 border-sky-500/30 text-sky-300" } %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border <%= type_classes[tx.transaction_type] %>">
                  <%= t("transactions.categorize.type.#{tx.transaction_type}") %>
                </span>
              </td>
              <td class="px-4 py-3 text-right font-mono text-slate-200 whitespace-nowrap">
                <%= number_to_currency(tx.amount, unit: "$", separator: ",", delimiter: ".", precision: 0) %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</section>

<script type="module">
  const toggleAll = document.getElementById("toggle-all");
  const counter = document.getElementById("selected-counter");
  const rangeFrom = document.getElementById("range-from");
  const rangeTo = document.getElementById("range-to");
  const applyRange = document.getElementById("apply-range");
  const checkboxes = Array.from(document.querySelectorAll(".preview-keep"));

  function refreshCounter() {
    if (!counter) return;
    const selected = checkboxes.filter((cb) => cb.checked).length;
    counter.textContent = selected + " de " + checkboxes.length + " seleccionados";
  }

  function applyDateRange() {
    const from = rangeFrom.value;
    const to = rangeTo.value;
    if (!from || !to) return;

    checkboxes.forEach((cb) => {
      const date = cb.dataset.date;
      cb.checked = date >= from && date <= to;
    });
    if (toggleAll) toggleAll.checked = checkboxes.every((cb) => cb.checked);
    refreshCounter();
  }

  if (toggleAll) {
    toggleAll.addEventListener("change", (e) => {
      checkboxes.forEach((cb) => { cb.checked = e.target.checked; });
      refreshCounter();
    });
  }
  if (applyRange) applyRange.addEventListener("click", applyDateRange);
  checkboxes.forEach((cb) => cb.addEventListener("change", refreshCounter));
  refreshCounter();
</script>
