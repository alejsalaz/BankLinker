<% content_for :title, "Categorizar - BankLinker" %>
<% content_for :breadcrumb, "Categorizar" %>

<section class="space-y-8 max-w-3xl mx-auto">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold text-slate-100">Categorizar</h1>
      <p class="text-slate-400 mt-1">Un movimiento, un click. Vamos a ponerle nombre a cada gasto.</p>
    </div>
    <span id="remaining_counter" class="inline-flex items-center gap-2 text-xs uppercase tracking-wide text-slate-400 bg-slate-900 border border-slate-800 rounded-full px-3 py-1.5">
      <span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
      <%= pluralize(@remaining, "pendiente") %>
    </span>
  </div>

  <%= turbo_frame_tag "current_card" do %>
    <%= render "card", transaction: @transaction, pockets: @pockets %>
  <% end %>
</section>
