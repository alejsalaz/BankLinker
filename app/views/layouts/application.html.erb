<!DOCTYPE html>
<html class="dark">
  <head>
    <title><%= content_for(:title) || "BankLinker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="BankLinker">
    <meta name="application-name" content="BankLinker">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#020617">
    <meta name="color-scheme" content="dark">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.webmanifest">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon-192.png" type="image/png" sizes="192x192">
    <link rel="apple-touch-icon" href="/icon-192.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/service-worker.js", { scope: "/" })
            .catch((err) => console.warn("[BankLinker] SW registration failed", err));
        });
      }
    </script>
  </head>

  <body class="bg-slate-950 text-slate-100 min-h-screen antialiased">
    <div class="flex min-h-screen">
      <%= render "shared/sidebar" %>

      <div class="flex-1 lg:pl-64">
        <%= render "shared/topbar" %>

        <% if notice.present? %>
          <div class="px-6 lg:px-10 mt-4">
            <div class="bg-emerald-500/10 border border-emerald-500/30 text-emerald-300 rounded-xl px-4 py-3 text-sm flex items-center gap-2">
              <%= heroicon :check_circle, klass: "w-5 h-5" %>
              <%= notice %>
            </div>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="px-6 lg:px-10 mt-4">
            <div class="bg-rose-500/10 border border-rose-500/30 text-rose-300 rounded-xl px-4 py-3 text-sm">
              <%= alert %>
            </div>
          </div>
        <% end %>

        <main class="px-6 lg:px-10 py-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
