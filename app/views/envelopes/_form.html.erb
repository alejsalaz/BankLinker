<%= form_with model: envelope, local: true, class: "space-y-5" do |f| %>
  <% if envelope.errors.any? %>
    <div class="bg-rose-500/10 border border-rose-500/30 text-rose-300 rounded-lg px-4 py-3 text-sm">
      <%= envelope.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, "Nombre", class: "block text-xs font-medium uppercase tracking-wide text-slate-400 mb-2" %>
      <%= f.text_field :name, required: true, placeholder: "Ej: Hogar, Inversiones, Transporte",
            class: "block w-full rounded-lg bg-slate-950 border border-slate-800 text-slate-100 text-sm px-3 py-2.5 focus:border-violet-500 focus:ring-1 focus:ring-violet-500" %>
    </div>

    <div>
      <%= f.label :color, "Color", class: "block text-xs font-medium uppercase tracking-wide text-slate-400 mb-2" %>
      <div class="grid grid-cols-10 gap-2">
        <% Envelope::AVAILABLE_COLORS.each do |color| %>
          <label class="relative cursor-pointer group" title="<%= color.titleize %>">
            <%= f.radio_button :color, color, class: "peer sr-only" %>
            <span class="block w-8 h-8 rounded-lg bg-<%= color %>-500 ring-2 ring-transparent peer-checked:ring-white peer-checked:ring-offset-2 peer-checked:ring-offset-slate-900 hover:scale-110 transition"></span>
          </label>
        <% end %>
      </div>
    </div>
  </div>

  <% if envelope.persisted? %>
    <div>
      <%= f.label :position, "Posición", class: "block text-xs font-medium uppercase tracking-wide text-slate-400 mb-2" %>
      <%= f.number_field :position,
            class: "block w-32 rounded-lg bg-slate-950 border border-slate-800 text-slate-100 text-sm px-3 py-2.5 focus:border-violet-500 focus:ring-1 focus:ring-violet-500" %>
    </div>
  <% end %>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit (envelope.persisted? ? "Guardar cambios" : "Crear sobre"),
          class: "inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-5 py-2.5 rounded-lg cursor-pointer transition" %>
    <%= link_to "Cancelar", envelopes_path, class: "text-sm text-slate-400 hover:text-slate-200" %>
  </div>
<% end %>
